{
  "name": "pixel-download",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @pixel/web",
    "dev:api": "npm run dev --workspace @pixel/api",
    "build": "npm run build --workspace @pixel/api && npm run build --workspace @pixel/web",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
